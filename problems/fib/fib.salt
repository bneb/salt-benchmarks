// Fibonacci -- LeetCode 509: Fibonacci Number (recursive and iterative)
package basalt

fn fib(n: i32) -> i32 {
    if n <= 1 { 
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

fn main() -> i32 {
    let n = 40;
    let res = fib(n);
    
    if res == 102334155 {
        return 0;
    }
    return 1;
}
