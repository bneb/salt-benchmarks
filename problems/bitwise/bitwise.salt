// Bitwise operations benchmark using popcount
package basalt

fn main(argc: i32) -> i32 {
    let iterations = 100000000;
    let mut total: u64 = 0;
    let base: u64 = (argc as u64) | 0x123456789ABCDEF0;
    
    for i in 0..iterations {
        let val = base ^ (i as u64);
        // Use popcount as function call (resolves to llvm.ctpop intrinsic)
        total += popcount(val);
    }
    
    let mut res = 1;
    if total > 0 {
        res = 0;
    }
    return res;
}
